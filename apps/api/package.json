{
    "name": "@meshmind/api",
    "version": "1.0.0",
    "main": "dist/main.js",
    "scripts": {
        "build": "tsc",
        "start": "node --env-file=../../.env dist/main.js",
        "dev": "bun --env-file=../../.env --watch src/main.ts",
        "lint": "biome lint --write .",
        "format": "biome format --write .",
        "type-check": "tsc --noEmit",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@better-auth/drizzle-adapter": "1.5.3",
        "@hono/node-server": "^1.13.5",
        "@meshmind/database": "workspace:*",
        "@meshmind/types": "workspace:*",
        "axios": "^1.13.5",
        "better-auth": "^1.5.3",
        "drizzle-orm": "^0.45.1",
        "hono": "^4.7.5",
        "openai": "^6.25.0",
        "uuid": "^9.0.1"
    },
    "devDependencies": {
        "@types/node": "^20.14.0",
        "@types/uuid": "^9.0.8",
        "nodemon": "^3.1.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.6.0"
    }
}
