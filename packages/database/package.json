{
    "name": "@meshmind/database",
    "version": "1.0.0",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "type-check": "tsc --noEmit",
        "clean": "rm -rf dist",
        "db:generate": "bun --env-file=../../.env x drizzle-kit generate",
        "db:push": "bun --env-file=../../.env x drizzle-kit push",
        "db:studio": "bun --env-file=../../.env x drizzle-kit studio"
    },
    "dependencies": {
        "postgres": "^3.4.3",
        "drizzle-orm": "^0.45.1"
    },
    "devDependencies": {
        "@types/node": "^20.14.0",
        "typescript": "^5.6.0",
        "drizzle-kit": "^0.28.0"
    }
}
